# -------------------------------------------------------
# TransitFlow environment variables
# Copy this file to .env and fill in real values.
# .env is gitignored and must NEVER be committed.
# -------------------------------------------------------

# -- NTA GTFS-Realtime API --
GTFSR_API_KEY=

# Optional overrides (defaults shown)
# GTFSR_API_URL=https://api.nationaltransport.ie/gtfsr/v2/gtfsr
# GTFSR_POLL_INTERVAL=60
# GTFSR_FORMAT=pb
# GTFSR_REQUEST_TIMEOUT=30
# GTFSR_AGENCY_FILTER=7778019
# GTFSR_RETAIN_FETCHES=20

# -- Database --
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=transitflow
# DB_USER=transitflow
# DB_PASSWORD=transitflow_dev

# -- Crowd Count Simulator --
# SIM_TIME_SCALE=1
# SIM_RANDOM_SEED=

# -- Prediction Runner --
# PREDICTION_DEBOUNCE_S=5.0
# PREDICTION_CYCLE_INTERVAL_S=120.0
# PREDICTION_ALIGHTING_FRACTION=0.05
# PREDICTION_DEFAULT_CAPACITY=80
# PREDICTION_OCCUPANCY_THRESHOLD=0.9
# PREDICTION_MIN_STRANDED=5
# PREDICTION_MIN_CONFIDENCE=0.3

# -- MQTT Broker --
# MQTT_BROKER_HOST=localhost
# MQTT_BROKER_PORT=8883
