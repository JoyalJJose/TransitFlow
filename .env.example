# -------------------------------------------------------
# TransitFlow environment variables
# Copy this file to .env and fill in real values.
# .env is gitignored and must NEVER be committed.
# -------------------------------------------------------

# -- NTA GTFS-Realtime API --
GTFSR_API_KEY=

# Optional overrides (defaults shown)
# GTFSR_API_URL=https://api.nationaltransport.ie/gtfsr/v2/gtfsr
# GTFSR_POLL_INTERVAL=60
# GTFSR_FORMAT=pb
# GTFSR_REQUEST_TIMEOUT=30
# GTFSR_AGENCY_FILTER=7778019
# GTFSR_RETAIN_FETCHES=20

# -- Database --
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=transitflow
# DB_USER=transitflow
# DB_PASSWORD=transitflow_dev

# -- Crowd Count Simulator --
# SIM_TIME_SCALE=1
# SIM_RANDOM_SEED=

# -- MQTT Broker --
# MQTT_BROKER_HOST=localhost
# MQTT_BROKER_PORT=8883
