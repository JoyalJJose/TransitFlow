# Force LF line endings for files that run inside Linux containers or on POSIX
# shells, so Windows checkouts don't break scripts (e.g. #!/bin/sh\r errors).
*.sh            text eol=lf
*.conf          text eol=lf
Dockerfile      text eol=lf
*.Dockerfile    text eol=lf
docker-compose*.yml text eol=lf

# Let git auto-detect text vs binary for everything else.
* text=auto
