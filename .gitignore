# Secrets / environment files
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments
.venv/
venv/
ENV/

# IDE / Editor
.vscode/
.idea/
.cursor/
*.swp
*.swo
*~

# pytest
.pytest_cache/

# Model weights (large binaries)
*.pt
*.pth
*.onnx

# Datasets (large -- 1GB+). Keep only the demo GTFS static feeds so the Docker
# demo can seed the database on a fresh clone; exclude the two Dublin Bus files
# that are too large for a lean repo.
/data/*
!/data/Transport Data/
/data/Transport Data/Dublin Bus/shapes.txt
/data/Transport Data/Dublin Bus/stop_times.txt

# Nested data/ directories (e.g. frontend mock data scaffolding)
src/Frontend/dashboard/src/data/

# TLS certs (generated per-environment)
docker/mosquitto/certs/*.crt
docker/mosquitto/certs/*.key
docker/mosquitto/certs/*.csr
docker/mosquitto/certs/*.srl

# Runtime artifacts created by backend/tests
received/
logs/
*.log
gtfsr_sample_output.txt
gtfsr_test_results.txt

# OS files
.DS_Store
Thumbs.db


# Ignore documentation/reference markdown
src/Frontend/REACT_VITE_COMMANDS.md

# Database backups
backups/

# Local temp and coverage artifacts
coverage/
.coverage*
*.tmp
*.bak
*.sqlite*


# Documentation
docs/PROJECT_OVERVIEW.md
